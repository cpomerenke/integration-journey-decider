<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Integration Journey Decider — Simpro × Employment Hero</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ═══════════════════════════════════════
       THEME TOKENS — DARK (default)
    ═══════════════════════════════════════ */
    :root,
    [data-theme="dark"] {
      /* EH brand fixed */
      --eh-purple:  #7622d7;
      --eh-deep:    #2d0649;
      --eh-dark:    #121214;
      --eh-purple2: #a569ff;
      --eh-purple3: #460078;
      --eh-lilac1:  #bb8eff;
      --eh-lilac2:  #d2b4ff;
      --eh-lilac3:  #e9d9ff;
      --eh-lime:    #bafc58;
      --eh-cyan:    #40d1ff;
      /* Simpro */
      --sim:        #0f2d66;
      --sim-mid:    #3a5fa0;
      /* Dark UI tokens */
      --bg:           #121214;
      --surface:      #1c1a24;
      --surface2:     #231f30;
      --surface3:     rgba(255,255,255,0.03);
      --border:       rgba(255,255,255,0.10);
      --border2:      rgba(118,34,215,0.35);
      --text:         #fdfbff;
      --text2:        rgba(253,251,255,0.65);
      --muted:        rgba(253,251,255,0.45);
      --shadow:       0 4px 24px rgba(0,0,0,0.45);
      --shadow-lg:    0 12px 48px rgba(0,0,0,0.6);
      /* Topbar */
      --topbar-bg:    linear-gradient(135deg, #1a0035 0%, #2d0649 50%, #1a0035 100%);
      --topbar-border:rgba(118,34,215,0.4);
      --topbar-glow:  radial-gradient(ellipse 600px 120px at 30% 50%, rgba(165,105,255,0.1) 0%, transparent 70%);
      --topbar-sep:   rgba(165,105,255,0.45);
      --topbar-label: rgba(165,105,255,0.55);
      --logo-filter:  none; /* white logo works on dark */
      --logo-filter-sim: none;
      /* Hero */
      --hero-h1:      var(--eh-lime);
      --hero-eyebrow: var(--eh-lime);
      --hero-substrong: var(--eh-lilac1);
      /* Body glow */
      --body-glow: radial-gradient(ellipse 900px 600px at 20% 10%, rgba(118,34,215,0.16) 0%, transparent 65%),
                   radial-gradient(ellipse 600px 400px at 80% 90%, rgba(70,0,120,0.12) 0%, transparent 60%);
      /* Partner banner */
      --banner-bg:    linear-gradient(135deg, #1a0035 0%, #2d0649 50%, #460078 100%);
      --banner-border:rgba(118,34,215,0.5);
      --banner-name:  var(--eh-lime);
      --banner-tag:   var(--eh-lime);
      --banner-text:  rgba(253,251,255,0.75);
      --banner-badge-bg: rgba(186,252,88,0.15);
      --banner-badge-border: rgba(186,252,88,0.4);
      --banner-badge-color: var(--eh-lime);
      --banner-dot:   var(--eh-lime);
      /* type banners */
      --ootb-bg:      rgba(64,209,255,0.08);
      --ootb-border:  rgba(64,209,255,0.3);
      --ootb-color:   #40d1ff;
      --custom-bg:    rgba(186,252,88,0.07);
      --custom-border:rgba(186,252,88,0.3);
      --custom-color: var(--eh-lime);
      /* section label */
      --section-hdr:  var(--eh-lime);
      /* flow col heads */
      --eh-head-bg:   linear-gradient(135deg, #1a0035, #460078);
      --sim-head-bg:  linear-gradient(135deg, #0a1a40, #0f2d66);
      /* flow section label colours */
      --eh-lbl-bg:    rgba(118,34,215,0.18);
      --eh-lbl-color: var(--eh-lilac1);
      --eh-lbl-border:rgba(118,34,215,0.35);
      --sim-lbl-bg:   rgba(15,45,102,0.25);
      --sim-lbl-color:#7ab4ff;
      --sim-lbl-border:rgba(58,95,160,0.4);
      /* flow items */
      --flow-item-color: rgba(253,251,255,0.65);
      --flow-item-bullet: var(--eh-lilac2);
      --flow-item-bullet-sim: #7ab4ff;
      --flow-divider: rgba(255,255,255,0.07);
      /* callouts */
      --callout-bg:   rgba(118,34,215,0.1);
      --callout-border:rgba(118,34,215,0.25);
      --callout-color:var(--eh-lilac2);
      --callout-blue-bg: rgba(15,45,102,0.2);
      --callout-blue-border: rgba(58,95,160,0.35);
      --callout-blue-color: #7ab4ff;
      /* connector */
      --via-bg:       rgba(118,34,215,0.2);
      --via-border:   rgba(118,34,215,0.5);
      --via-color:    var(--eh-lilac1);
      --arrow-divider:rgba(255,255,255,0.07);
      --arrow-lbl:    rgba(253,251,255,0.35);
      /* arrows */
      --arrow-r-color:#bafc58;
      --arrow-l-color:#40d1ff;
      /* bidir */
      --bidir-label:  rgba(253,251,255,0.35);
      --bidir-pill-bg:rgba(118,34,215,0.15);
      --bidir-pill-border:rgba(118,34,215,0.3);
      --bidir-pill-color:var(--eh-lilac2);
      --arc-color:    #bafc58;
      /* table */
      --th-color:     rgba(253,251,255,0.3);
      --td-row-hover: rgba(118,34,215,0.05);
      --td-divider:   rgba(255,255,255,0.04);
      --td-first:     var(--eh-lilac1);
      --boundary-color:rgba(253,251,255,0.3);
      /* dir badges */
      --badge-sim-bg:  rgba(118,34,215,0.15);
      --badge-sim-color:var(--eh-lilac1);
      --badge-sim-border:rgba(118,34,215,0.3);
      --badge-eh-bg:   rgba(64,209,255,0.1);
      --badge-eh-color:#40d1ff;
      --badge-eh-border:rgba(64,209,255,0.3);
      --badge-bi-bg:   rgba(186,252,88,0.1);
      --badge-bi-color:var(--eh-lime);
      --badge-bi-border:rgba(186,252,88,0.3);
      --badge-bnd-bg:  rgba(255,255,255,0.05);
      --badge-bnd-color:rgba(253,251,255,0.3);
      --badge-bnd-border:rgba(255,255,255,0.1);
      /* status pills */
      --pill-ootb-bg:  rgba(64,209,255,0.1);
      --pill-ootb-color:#40d1ff;
      --pill-ootb-border:rgba(64,209,255,0.3);
      --pill-ootb-dot: #40d1ff;
      --pill-cust-bg:  rgba(186,252,88,0.1);
      --pill-cust-color:var(--eh-lime);
      --pill-cust-border:rgba(186,252,88,0.3);
      --pill-cust-dot: var(--eh-lime);
      /* notes */
      --note-title:   var(--eh-lilac1);
      /* buttons */
      --btn-show-bg:  var(--eh-lime);
      --btn-show-color:#121214;
      --btn-show-shadow:rgba(186,252,88,0.3);
      --btn-show-hover:#d4ff7a;
      --btn-reset-border:rgba(255,255,255,0.15);
      --btn-reset-color:var(--muted);
      /* platform cards */
      --card-selected-eh-bg: linear-gradient(145deg, rgba(118,34,215,0.15), rgba(45,6,73,0.3));
      --card-selected-eh-shadow: 0 0 0 1px #7622d7, 0 8px 32px rgba(118,34,215,0.3);
      --card-selected-sim-bg: linear-gradient(145deg, rgba(15,45,102,0.3), rgba(15,45,102,0.15));
      --card-selected-sim-shadow: 0 0 0 1px #3a5fa0, 0 8px 32px rgba(15,45,102,0.3);
      --p-name-color: #fdfbff;
      --locked-badge-color: rgba(253,251,255,0.3);
      --locked-badge-bg:   rgba(255,255,255,0.05);
      --locked-badge-border:rgba(255,255,255,0.1);
      --p-icon-eh-bg:  rgba(118,34,215,0.2);
      --p-icon-eh-border:rgba(118,34,215,0.35);
      --p-icon-sim-bg: rgba(15,45,102,0.3);
      --p-icon-sim-border:rgba(58,95,160,0.4);
    }

    /* ═══════════════════════════════════════
       THEME TOKENS — LIGHT
    ═══════════════════════════════════════ */
    [data-theme="light"] {
      --bg:           #f4f0fa;
      --surface:      #ffffff;
      --surface2:     #f0ebff;
      --surface3:     rgba(118,34,215,0.03);
      --border:       rgba(118,34,215,0.15);
      --border2:      rgba(118,34,215,0.3);
      --text:         #18103a;
      --text2:        rgba(24,16,58,0.75);
      --muted:        rgba(24,16,58,0.5);
      --shadow:       0 4px 24px rgba(118,34,215,0.08);
      --shadow-lg:    0 12px 48px rgba(118,34,215,0.14);
      /* Topbar stays dark — always on-brand */
      --topbar-bg:    linear-gradient(135deg, #1a0035 0%, #2d0649 50%, #1a0035 100%);
      --topbar-border:rgba(118,34,215,0.4);
      --topbar-glow:  radial-gradient(ellipse 600px 120px at 30% 50%, rgba(165,105,255,0.1) 0%, transparent 70%);
      --topbar-sep:   rgba(165,105,255,0.45);
      --topbar-label: rgba(165,105,255,0.55);
      --logo-filter:  none;
      --logo-filter-sim: none;
      /* Hero */
      --hero-h1:      var(--eh-purple);
      --hero-eyebrow: var(--eh-purple);
      --hero-substrong: var(--eh-purple);
      /* Body glow */
      --body-glow: radial-gradient(ellipse 900px 600px at 20% 10%, rgba(118,34,215,0.06) 0%, transparent 65%),
                   radial-gradient(ellipse 600px 400px at 80% 90%, rgba(118,34,215,0.04) 0%, transparent 60%);
      /* Partner banner — stays dark */
      --banner-bg:    linear-gradient(135deg, #1a0035 0%, #2d0649 50%, #460078 100%);
      --banner-border:rgba(118,34,215,0.5);
      --banner-name:  var(--eh-lime);
      --banner-tag:   var(--eh-lime);
      --banner-text:  rgba(253,251,255,0.75);
      --banner-badge-bg: rgba(186,252,88,0.15);
      --banner-badge-border: rgba(186,252,88,0.4);
      --banner-badge-color: var(--eh-lime);
      --banner-dot:   var(--eh-lime);
      /* type banners */
      --ootb-bg:      rgba(15,45,102,0.06);
      --ootb-border:  rgba(15,45,102,0.25);
      --ootb-color:   #0f2d66;
      --custom-bg:    rgba(118,34,215,0.06);
      --custom-border:rgba(118,34,215,0.25);
      --custom-color: var(--eh-purple);
      /* section label */
      --section-hdr:  var(--eh-purple);
      /* flow col heads — always dark */
      --eh-head-bg:   linear-gradient(135deg, #1a0035, #460078);
      --sim-head-bg:  linear-gradient(135deg, #0a1a40, #0f2d66);
      /* flow section labels */
      --eh-lbl-bg:    rgba(118,34,215,0.08);
      --eh-lbl-color: #6010b0;
      --eh-lbl-border:rgba(118,34,215,0.2);
      --sim-lbl-bg:   rgba(15,45,102,0.08);
      --sim-lbl-color:#0f2d66;
      --sim-lbl-border:rgba(15,45,102,0.2);
      /* flow items */
      --flow-item-color: rgba(24,16,58,0.75);
      --flow-item-bullet: #a569ff;
      --flow-item-bullet-sim: #3a5fa0;
      --flow-divider: rgba(118,34,215,0.1);
      /* callouts */
      --callout-bg:    rgba(118,34,215,0.05);
      --callout-border:rgba(118,34,215,0.2);
      --callout-color: #5a10b0;
      --callout-blue-bg: rgba(15,45,102,0.05);
      --callout-blue-border: rgba(15,45,102,0.2);
      --callout-blue-color: #0f2d66;
      /* connector */
      --via-bg:       rgba(118,34,215,0.1);
      --via-border:   rgba(118,34,215,0.35);
      --via-color:    var(--eh-purple);
      --arrow-divider:rgba(118,34,215,0.1);
      --arrow-lbl:    rgba(24,16,58,0.4);
      /* arrows */
      --arrow-r-color:#7622d7;
      --arrow-l-color:#0f2d66;
      /* bidir */
      --bidir-label:  rgba(24,16,58,0.4);
      --bidir-pill-bg:rgba(118,34,215,0.08);
      --bidir-pill-border:rgba(118,34,215,0.2);
      --bidir-pill-color:#6010b0;
      --arc-color:    #7622d7;
      /* table */
      --th-color:     rgba(24,16,58,0.4);
      --td-row-hover: rgba(118,34,215,0.03);
      --td-divider:   rgba(118,34,215,0.06);
      --td-first:     #18103a;
      --boundary-color:rgba(24,16,58,0.35);
      /* dir badges */
      --badge-sim-bg:  rgba(118,34,215,0.08);
      --badge-sim-color:#6010b0;
      --badge-sim-border:rgba(118,34,215,0.2);
      --badge-eh-bg:   rgba(15,45,102,0.08);
      --badge-eh-color:#0f2d66;
      --badge-eh-border:rgba(15,45,102,0.2);
      --badge-bi-bg:   rgba(118,34,215,0.08);
      --badge-bi-color:var(--eh-purple);
      --badge-bi-border:rgba(118,34,215,0.2);
      --badge-bnd-bg:  rgba(0,0,0,0.04);
      --badge-bnd-color:rgba(24,16,58,0.4);
      --badge-bnd-border:rgba(0,0,0,0.12);
      /* status pills */
      --pill-ootb-bg:    rgba(15,45,102,0.08);
      --pill-ootb-color: #0f2d66;
      --pill-ootb-border:rgba(15,45,102,0.2);
      --pill-ootb-dot:   #0f2d66;
      --pill-cust-bg:    rgba(118,34,215,0.08);
      --pill-cust-color: var(--eh-purple);
      --pill-cust-border:rgba(118,34,215,0.25);
      --pill-cust-dot:   var(--eh-purple);
      /* notes */
      --note-title:   #18103a;
      /* buttons */
      --btn-show-bg:   var(--eh-purple);
      --btn-show-color:#ffffff;
      --btn-show-shadow:rgba(118,34,215,0.3);
      --btn-show-hover:#5c0fbf;
      --btn-reset-border:rgba(118,34,215,0.25);
      --btn-reset-color:var(--muted);
      /* platform cards */
      --card-selected-eh-bg: linear-gradient(145deg, rgba(118,34,215,0.08), rgba(118,34,215,0.04));
      --card-selected-eh-shadow: 0 0 0 2px #7622d7, 0 8px 24px rgba(118,34,215,0.15);
      --card-selected-sim-bg: linear-gradient(145deg, rgba(15,45,102,0.08), rgba(15,45,102,0.04));
      --card-selected-sim-shadow: 0 0 0 2px #3a5fa0, 0 8px 24px rgba(15,45,102,0.15);
      --p-name-color:  #18103a;
      --locked-badge-color: rgba(24,16,58,0.4);
      --locked-badge-bg:    rgba(0,0,0,0.04);
      --locked-badge-border:rgba(0,0,0,0.1);
      --p-icon-eh-bg:   rgba(118,34,215,0.1);
      --p-icon-eh-border:rgba(118,34,215,0.2);
      --p-icon-sim-bg:  rgba(15,45,102,0.08);
      --p-icon-sim-border:rgba(58,95,160,0.2);
    }

    /* ═══════════════════════════════════════
       BASE
    ═══════════════════════════════════════ */
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex; flex-direction: column; align-items: center;
      padding: 0 0 80px;
      transition: background 0.3s ease, color 0.3s ease;
    }
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background: var(--body-glow);
      transition: background 0.3s ease;
    }

    /* ═══════════════════════════════════════
       TOPBAR
    ═══════════════════════════════════════ */
    .topbar {
      width: 100%;
      background: var(--topbar-bg);
      border-bottom: 1px solid var(--topbar-border);
      padding: 0 48px;
      display: flex; align-items: center; justify-content: space-between;
      height: 72px;
      position: relative; z-index: 10; overflow: hidden;
    }
    .topbar::after {
      content: ''; position: absolute; inset: 0;
      background: var(--topbar-glow); pointer-events: none;
    }
    .topbar-logos { display: flex; align-items: center; gap: 28px; position: relative; z-index: 1; }
    .topbar-logo-eh  { height: 220px; width: auto; display: block; filter: var(--logo-filter); }
    .topbar-logo-sim { height: 20px;  width: auto; display: block; opacity: 0.9; filter: var(--logo-filter-sim); }
    .topbar-sep {
      color: var(--topbar-sep); font-size: 26px; font-weight: 200;
      line-height: 1; font-family: 'Lexend', sans-serif;
    }
    .topbar-right {
      display: flex; align-items: center; gap: 16px; position: relative; z-index: 1;
    }
    .topbar-label {
      font-family: 'Lexend', sans-serif; font-size: 10px; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--topbar-label);
    }

    /* ── THEME TOGGLE ── */
    .theme-toggle {
      display: flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 100px; padding: 5px 6px; cursor: pointer;
      transition: background 0.2s;
      position: relative; z-index: 1;
    }
    .theme-toggle:hover { background: rgba(255,255,255,0.14); }
    .theme-toggle-icon {
      font-size: 14px; line-height: 1;
      width: 26px; height: 26px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s, transform 0.2s;
    }
    .theme-toggle-icon.active {
      background: rgba(255,255,255,0.18);
      transform: scale(1.1);
    }

    /* ═══════════════════════════════════════
       HERO
    ═══════════════════════════════════════ */
    .hero {
      text-align: center; padding: 60px 24px 48px;
      position: relative; z-index: 1; width: 100%;
    }
    .hero-eyebrow {
      font-family: 'Lexend', sans-serif; font-size: 13px; font-weight: 600;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--hero-eyebrow); margin-bottom: 14px;
      transition: color 0.3s;
    }
    .hero h1 {
      font-family: 'Lexend', sans-serif; font-weight: 800;
      font-size: clamp(32px, 5vw, 56px);
      line-height: 1.06; letter-spacing: -0.03em;
      color: var(--text); margin-bottom: 16px;
      text-transform: uppercase; transition: color 0.3s;
    }
    .hero h1 em { font-style: normal; color: var(--hero-h1); transition: color 0.3s; }
    .hero-sub {
      font-size: 17px; color: var(--muted); max-width: 520px;
      margin: 0 auto; line-height: 1.65;
    }
    .hero-sub strong { color: var(--hero-substrong); font-weight: 600; transition: color 0.3s; }

    /* ═══════════════════════════════════════
       MAIN WRAP
    ═══════════════════════════════════════ */
    .main-wrap {
      width: 100%; max-width: 1000px; padding: 0 24px;
      position: relative; z-index: 1;
    }
    .step-row { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; }
    .step-num {
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--surface2); border: 1.5px solid var(--border2);
      color: var(--eh-purple); font-size: 13px; font-weight: 700;
      font-family: 'Lexend', sans-serif;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      transition: background 0.3s, border-color 0.3s;
    }
    .step-num.active { background: var(--eh-purple); border-color: var(--eh-purple); color: #fff; }
    .step-title {
      font-family: 'Lexend', sans-serif; font-size: 13px; font-weight: 700;
      color: var(--muted); letter-spacing: 0.14em; text-transform: uppercase;
    }

    /* ═══════════════════════════════════════
       PLATFORM GRID
    ═══════════════════════════════════════ */
    .platform-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px;
    }
    .platform-card {
      border: 1.5px solid var(--border); border-radius: 16px; padding: 22px 20px;
      cursor: pointer; background: var(--surface);
      transition: all 0.2s ease; position: relative; overflow: hidden; user-select: none;
    }
    .platform-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      opacity: 0; transition: opacity 0.2s;
    }
    .platform-card.eh-card::before { background: linear-gradient(90deg, #460078, #a569ff); }
    .platform-card.sim-card::before { background: linear-gradient(90deg, #0f2d66, #3a5fa0); }
    .platform-card:hover:not(.locked) {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(118,34,215,0.2); border-color: rgba(118,34,215,0.4);
    }
    .platform-card:hover:not(.locked)::before { opacity: 1; }
    .platform-card.selected.eh-card {
      border-color: var(--eh-purple);
      background: var(--card-selected-eh-bg);
      box-shadow: var(--card-selected-eh-shadow);
    }
    .platform-card.selected.sim-card {
      border-color: var(--sim-mid);
      background: var(--card-selected-sim-bg);
      box-shadow: var(--card-selected-sim-shadow);
    }
    .platform-card.selected::before { opacity: 1; }
    .platform-card.locked { cursor: default; }
    .platform-card.locked:not(.selected) { opacity: 0.4; }
    .platform-card.locked:hover:not(.selected) { transform: none; box-shadow: none; border-color: var(--border); }

    .p-icon {
      width: 40px; height: 40px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 19px; margin-bottom: 14px;
    }
    .p-icon.eh { background: var(--p-icon-eh-bg); border: 1px solid var(--p-icon-eh-border); }
    .p-icon.sim { background: var(--p-icon-sim-bg); border: 1px solid var(--p-icon-sim-border); }
    .p-name {
      font-family: 'Lexend', sans-serif; font-weight: 700; font-size: 14.5px;
      color: var(--p-name-color); margin-bottom: 5px; line-height: 1.3; transition: color 0.3s;
    }
    .p-desc { font-size: 13px; color: var(--muted); line-height: 1.45; }
    .p-check {
      position: absolute; top: 16px; right: 16px; width: 22px; height: 22px; border-radius: 50%;
      background: var(--eh-lime); display: flex; align-items: center; justify-content: center;
      opacity: 0; transform: scale(0.5); transition: all 0.2s;
    }
    .platform-card.sim-card .p-check { background: #40d1ff; }
    .platform-card.selected .p-check { opacity: 1; transform: scale(1); }
    .p-check::after { content: '✓'; color: #121214; font-size: 11px; font-weight: 800; }
    .locked-badge {
      display: inline-flex; align-items: center; gap: 4px; margin-top: 10px;
      font-size: 11px; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.06em;
      color: var(--locked-badge-color); background: var(--locked-badge-bg);
      border: 1px solid var(--locked-badge-border); padding: 3px 8px; border-radius: 4px;
    }

    /* ═══════════════════════════════════════
       SHOW BUTTON
    ═══════════════════════════════════════ */
    .btn-show-integration {
      padding: 15px 48px; border-radius: 6px; border: none;
      background: var(--btn-show-bg); color: var(--btn-show-color);
      font-family: 'Lexend', sans-serif; font-size: 14px; font-weight: 800;
      letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: all 0.2s;
      box-shadow: 0 4px 24px var(--btn-show-shadow);
    }
    .btn-show-integration:hover {
      background: var(--btn-show-hover); transform: translateY(-2px);
      box-shadow: 0 8px 32px var(--btn-show-shadow);
    }

    /* ═══════════════════════════════════════
       RESULT PANEL
    ═══════════════════════════════════════ */
    #result-panel { display: none; }
    #result-panel.visible { display: block; animation: fadeUp 0.4s ease both; }

    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    @keyframes pulse  { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:.4;transform:scale(.7);} }
    @keyframes flowR  { 0%{background-position:-100% 0} 100%{background-position:100% 0} }
    @keyframes flowL  { 0%{background-position:100% 0} 100%{background-position:-100% 0} }

    .section-hdr {
      font-family: 'Lexend', sans-serif; font-size: 12px; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--section-hdr); margin-bottom: 14px; transition: color 0.3s;
    }

    /* ═══════════════════════════════════════
       PARTNER BANNER
    ═══════════════════════════════════════ */
    .partner-hero {
      border-radius: 14px; padding: 22px 28px; margin-bottom: 18px;
      display: flex; align-items: center; gap: 20px;
      position: relative; overflow: hidden;
      background: var(--banner-bg); border: 1px solid var(--banner-border);
    }
    .partner-hero::before {
      content: ''; position: absolute; top: -40px; right: -40px;
      width: 180px; height: 180px; border-radius: 50%;
      background: radial-gradient(circle, rgba(186,252,88,0.07) 0%, transparent 70%);
      pointer-events: none;
    }
    .partner-icon-wrap {
      width: 48px; height: 48px; border-radius: 10px; flex-shrink: 0;
      background: rgba(186,252,88,0.12); border: 1px solid rgba(186,252,88,0.3);
      display: flex; align-items: center; justify-content: center; font-size: 22px;
      position: relative; z-index: 1;
    }
    .partner-info { flex: 1; position: relative; z-index: 1; }
    .partner-type {
      font-family: 'Lexend', sans-serif; font-size: 11px; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--banner-tag); margin-bottom: 3px;
    }
    .partner-name {
      font-family: 'Lexend', sans-serif; font-size: 26px; font-weight: 800;
      color: #fdfbff; letter-spacing: -0.02em;
      text-transform: uppercase; line-height: 1; margin-bottom: 4px;
    }
    .partner-tagline { font-size: 14px; color: var(--banner-text); line-height: 1.55; max-width: 560px; }
    .partner-badge {
      display: inline-flex; align-items: center; gap: 7px; margin-top: 10px;
      padding: 6px 14px; border-radius: 5px; font-size: 12px; font-weight: 700;
      font-family: 'Lexend', sans-serif; letter-spacing: 0.07em; text-transform: uppercase;
      background: var(--banner-badge-bg); border: 1px solid var(--banner-badge-border);
      color: var(--banner-badge-color);
    }
    .partner-badge .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--banner-dot); animation: pulse 2s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════
       TYPE BANNER
    ═══════════════════════════════════════ */
    .type-banner {
      display: flex; align-items: center; gap: 13px; padding: 13px 18px;
      border-radius: 10px; margin-bottom: 24px; font-size: 14px; font-weight: 600;
      transition: background 0.3s, border-color 0.3s, color 0.3s;
    }
    .type-banner.ootb   { background: var(--ootb-bg);   border: 1.5px solid var(--ootb-border);   color: var(--ootb-color); }
    .type-banner.custom { background: var(--custom-bg); border: 1.5px solid var(--custom-border); color: var(--custom-color); }
    .type-banner-icon { font-size: 20px; }
    .type-banner-text { flex: 1; }
    .type-banner-text strong { display: block; margin-bottom: 2px; font-family: 'Lexend', sans-serif; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; }
    .type-banner-text span { font-weight: 400; font-size: 13px; opacity: 0.8; color: var(--muted); }

    /* ═══════════════════════════════════════
       LEGEND BAR
    ═══════════════════════════════════════ */
    .legend-bar {
      display: flex; align-items: center; gap: 18px; padding: 11px 16px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; margin-bottom: 24px; flex-wrap: wrap; transition: background 0.3s, border-color 0.3s;
    }
    .legend-lbl {
      font-family: 'Lexend', sans-serif; font-size: 11px; font-weight: 700;
      letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted);
    }
    .legend-item { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--muted); }
    .status-pill {
      display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 700;
      padding: 4px 10px; border-radius: 4px; font-family: 'Lexend', sans-serif;
      letter-spacing: 0.06em; text-transform: uppercase; transition: all 0.3s;
    }
    .status-pill::before { content: ''; width: 5px; height: 5px; border-radius: 50%; }
    .status-pill.ootb   { background: var(--pill-ootb-bg);  color: var(--pill-ootb-color);  border: 1px solid var(--pill-ootb-border); }
    .status-pill.ootb::before  { background: var(--pill-ootb-dot); }
    .status-pill.custom { background: var(--pill-cust-bg);  color: var(--pill-cust-color);  border: 1px solid var(--pill-cust-border); }
    .status-pill.custom::before{ background: var(--pill-cust-dot); }

    /* ═══════════════════════════════════════
       FLOW DIAGRAM
    ═══════════════════════════════════════ */
    .flow-diagram {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; margin-bottom: 24px; box-shadow: var(--shadow);
      transition: background 0.3s, border-color 0.3s;
    }
    .flow-diagram-hdr {
      padding: 12px 20px; background: var(--surface3); border-bottom: 1px solid var(--border);
      font-family: 'Lexend', sans-serif; font-size: 11px; font-weight: 700;
      color: var(--muted); letter-spacing: 0.18em; text-transform: uppercase;
    }
    .flow-body { padding: 20px 16px; display: grid; align-items: stretch; }
    .flow-body.two-col   { grid-template-columns: 1fr 108px 1fr; }
    .flow-body.three-col { grid-template-columns: 1fr 80px 1fr 80px 1fr; }

    .flow-col { border-radius: 10px; overflow: hidden; border: 1px solid var(--border); transition: border-color 0.3s; }
    .flow-col-head { padding: 12px 14px; }
    .flow-col-head-title { font-family: 'Lexend', sans-serif; font-size: 13px; font-weight: 700; color: #fff; }
    .flow-col-head-sub { font-size: 11.5px; color: rgba(255,255,255,0.5); margin-top: 2px; }
    .eh-head  { background: var(--eh-head-bg); }
    .sim-head { background: var(--sim-head-bg); }
    .flow-col-body { padding: 13px 12px; display: flex; flex-direction: column; gap: 11px; }
    .flow-sec-label {
      font-family: 'Lexend', sans-serif; font-size: 9.5px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase; padding: 3px 7px;
      border-radius: 3px; display: inline-block; margin-bottom: 6px; transition: all 0.3s;
    }
    .eh-lbl  { background: var(--eh-lbl-bg);  color: var(--eh-lbl-color);  border: 1px solid var(--eh-lbl-border); }
    .sim-lbl { background: var(--sim-lbl-bg); color: var(--sim-lbl-color); border: 1px solid var(--sim-lbl-border); }
    .flow-items { display: flex; flex-direction: column; gap: 5px; }
    .flow-item { display: flex; align-items: flex-start; gap: 7px; font-size: 12.5px; color: var(--flow-item-color); line-height: 1.4; transition: color 0.3s; }
    .flow-item::before { content: '–'; font-size: 11px; margin-top: 2px; flex-shrink: 0; color: var(--flow-item-bullet); }
    .flow-col.sim-fcol .flow-item::before { color: var(--flow-item-bullet-sim); }
    .flow-divider { height: 1px; background: var(--flow-divider); }
    .flow-callout {
      padding: 9px 11px; border-radius: 7px; font-size: 12px; line-height: 1.55;
      color: var(--callout-color); background: var(--callout-bg); border: 1px solid var(--callout-border);
      transition: all 0.3s;
    }
    .flow-callout.blue { color: var(--callout-blue-color); background: var(--callout-blue-bg); border-color: var(--callout-blue-border); }
    .flow-callout-icon { margin-bottom: 3px; display: block; }

    /* ── CONNECTOR ── */
    .flow-connector { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0; gap: 0; }
    .flow-via {
      font-family: 'Lexend', sans-serif; font-size: 9.5px; font-weight: 700;
      letter-spacing: 0.08em; text-align: center; padding: 6px 10px;
      border-radius: 20px; margin: 4px 0; white-space: nowrap;
      background: var(--via-bg); border: 1px solid var(--via-border); color: var(--via-color);
      text-transform: uppercase; transition: all 0.3s;
    }
    .arrow-row {
      width: 100%; display: flex; flex-direction: column; align-items: center;
      gap: 3px; padding: 6px 0; border-top: 1px solid var(--arrow-divider);
    }
    .arrow-row:first-child { border-top: none; }
    .arrow-lbl { font-family: 'JetBrains Mono', monospace; font-size: 8.5px; text-align: center; color: var(--arrow-lbl); line-height: 1.3; }
    .arrow-track { width: 100%; height: 14px; position: relative; display: flex; align-items: center; }
    .arrow-line { position: absolute; left: 4px; right: 4px; top: 50%; transform: translateY(-50%); height: 1.5px; border-radius: 2px; }
    .arrow-line.to-right {
      background: linear-gradient(90deg, transparent, var(--arrow-r-color), transparent);
      background-size: 200% 100%; animation: flowR 1.8s linear infinite;
    }
    .arrow-line.to-left {
      background: linear-gradient(270deg, transparent, var(--arrow-l-color), transparent);
      background-size: 200% 100%; animation: flowL 1.8s linear infinite;
    }
    .arrowhead-r { position: absolute; right: 0; top: 50%; transform: translateY(-50%); width:0; height:0; border-top:5px solid transparent; border-bottom:5px solid transparent; border-left:7px solid var(--arrow-r-color); }
    .arrowhead-l { position: absolute; left:  0; top: 50%; transform: translateY(-50%); width:0; height:0; border-top:5px solid transparent; border-bottom:5px solid transparent; border-right:7px solid var(--arrow-l-color); }

    /* ── BIDIR ARC ── */
    .bidir-wrap {
      background: var(--surface); border-left: 1px solid var(--border);
      border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
      border-radius: 0 0 14px 14px; transition: background 0.3s, border-color 0.3s;
    }
    .bidir-inner { padding: 12px 18px 20px; display: flex; flex-direction: column; align-items: center; }
    .bidir-label {
      font-family: 'Lexend', sans-serif; font-size: 10.5px; font-weight: 700;
      letter-spacing: 0.12em; color: var(--bidir-label); text-transform: uppercase;
      margin-bottom: 8px; text-align: center; transition: color 0.3s;
    }
    .bidir-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; margin-top: 6px; }
    .bidir-pill {
      font-size: 12.5px; color: var(--bidir-pill-color); padding: 4px 12px; border-radius: 4px;
      background: var(--bidir-pill-bg); border: 1px solid var(--bidir-pill-border); transition: all 0.3s;
    }

    /* ═══════════════════════════════════════
       DATA TABLE
    ═══════════════════════════════════════ */
    .data-table {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; overflow: hidden; margin-bottom: 24px; box-shadow: var(--shadow);
      transition: background 0.3s, border-color 0.3s;
    }
    .data-table-hdr {
      padding: 12px 20px; background: var(--surface3); border-bottom: 1px solid var(--border);
      font-family: 'Lexend', sans-serif; font-size: 11px; font-weight: 700;
      color: var(--muted); letter-spacing: 0.18em; text-transform: uppercase;
    }
    .data-table table { width: 100%; border-collapse: collapse; }
    .data-table th {
      padding: 10px 16px; font-family: 'Lexend', sans-serif; font-size: 11px; font-weight: 700;
      color: var(--th-color); text-transform: uppercase; letter-spacing: 0.12em;
      border-bottom: 1px solid var(--border); text-align: left; transition: color 0.3s;
    }
    .data-table td {
      padding: 11px 16px; font-size: 13.5px;
      border-bottom: 1px solid var(--td-divider); vertical-align: middle; color: var(--muted); transition: all 0.3s;
    }
    .data-table td:first-child { color: var(--td-first); font-weight: 600; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: var(--td-row-hover); }
    .dir-badge {
      display: inline-flex; align-items: center; gap: 3px; font-size: 11px; font-weight: 700;
      padding: 3px 9px; border-radius: 4px; font-family: 'Lexend', sans-serif;
      letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; transition: all 0.3s;
    }
    .dir-badge.to-sim   { background: var(--badge-sim-bg);  color: var(--badge-sim-color);  border: 1px solid var(--badge-sim-border); }
    .dir-badge.to-eh    { background: var(--badge-eh-bg);   color: var(--badge-eh-color);   border: 1px solid var(--badge-eh-border); }
    .dir-badge.bidir    { background: var(--badge-bi-bg);   color: var(--badge-bi-color);   border: 1px solid var(--badge-bi-border); }
    .dir-badge.boundary { background: var(--badge-bnd-bg);  color: var(--badge-bnd-color);  border: 1px solid var(--badge-bnd-border); }

    /* ═══════════════════════════════════════
       NOTES GRID
    ═══════════════════════════════════════ */
    .notes-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 24px; }
    .note-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 14px; padding: 20px; box-shadow: var(--shadow);
      transition: all 0.2s;
    }
    .note-card:hover { border-color: rgba(118,34,215,0.35); }
    .note-card-icon { font-size: 22px; margin-bottom: 9px; display: block; }
    .note-card-title {
      font-family: 'Lexend', sans-serif; font-size: 13px; font-weight: 700;
      color: var(--note-title); margin-bottom: 6px; letter-spacing: 0.02em;
      text-transform: uppercase; transition: color 0.3s;
    }
    .note-card-body { font-size: 13.5px; color: var(--muted); line-height: 1.65; }

    /* ═══════════════════════════════════════
       RESET BUTTON
    ═══════════════════════════════════════ */
    .reset-row { text-align: center; margin-top: 8px; }
    .btn-reset {
      padding: 11px 28px; border-radius: 6px;
      border: 1.5px solid var(--btn-reset-border); background: transparent;
      font-family: 'Lexend', sans-serif; font-size: 13px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--btn-reset-color); cursor: pointer; transition: all 0.2s;
    }
    .btn-reset:hover { border-color: var(--eh-purple); color: var(--eh-purple); background: rgba(118,34,215,0.06); }

    /* ═══════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════ */
    @media (max-width: 660px) {
      .topbar { padding: 0 20px; }
      .topbar-logo-eh { height: 140px; }
      .topbar-label { display: none; }
      .platform-grid { grid-template-columns: 1fr; }
      .flow-body.two-col, .flow-body.three-col { grid-template-columns: 1fr; }
      .flow-connector { flex-direction: row; flex-wrap: wrap; justify-content: center; padding: 10px 0; }
      .notes-grid { grid-template-columns: 1fr; }
      .hero h1 { font-size: 26px; }
    }
  </style>
</head>
