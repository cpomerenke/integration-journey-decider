          { lbl:'Stays in Simpro', lCls:'sim-lbl', items:['Job codes & cost centres','Subcontractors, parts & assets','Invoicing & billing records'] },
        ],
        callout:{ cls:'blue', icon:'🔧', txt:"What stays in Simpro is configurable — Aloka can tailor exactly which data crosses the integration boundary." }
      },
      a2:[ { dir:'r', lbl:'Work types' }, { dir:'r', lbl:'Allowances' }, { dir:'r', lbl:'Timesheet data' } ],
      v2Cls:'aloka-via', v2Lbl:'via Aloka',
      cPAY:{ title:'Employment Hero Payroll', sub:'Payroll & workforce platform', hCls:'eh-head',
        secs:[
          { lbl:'Payroll Processing', lCls:'eh-lbl', items:['Pay runs & pay period management','Gross & net pay calculations','Superannuation & tax lodgements'] },
          { lbl:'Timesheets & Hours', lCls:'eh-lbl', items:['Labour hours from Simpro','Overtime & allowance calculations','Award interpretation & penalty rates'] },
          { lbl:'Employee Data (from EH HR)', lCls:'eh-lbl', items:['Employee profiles & tax details','Leave balances & accruals','Banking & payment details'] },
          { lbl:'Compliance & Reporting', lCls:'eh-lbl', items:['Single Touch Payroll (STP) reporting','PAYG withholding & ATO lodgements','Payroll summaries & audit trail'] },
        ],
        callout:{ cls:'', icon:'💰', txt:'EH Payroll receives job-level labour data from Simpro and stays in sync with EH HR — ensuring accurate pay runs without manual re-entry.' }
      },
      bidirFields:['Employee profile','Leave','Leave balances','Payslips'],
      dp:[
        { f:'Employee Profile',              from:'EH HR',  to:'Simpro',     dir:'to-sim', s:'custom' },
        { f:'Leave Status',                  from:'EH HR',  to:'Simpro',     dir:'to-sim', s:'custom' },
        { f:'Certifications & Licences',     from:'EH HR',  to:'Simpro',     dir:'to-sim', s:'custom' },
        { f:'Employee Profile & Tax Details',from:'EH HR',  to:'EH Payroll', dir:'bidir',  s:'custom' },
        { f:'Leave Balances & Payslips',     from:'EH HR',  to:'EH Payroll', dir:'bidir',  s:'custom' },
        { f:'Work Types & Allowances',       from:'Simpro', to:'EH Payroll', dir:'to-eh',  s:'custom' },
        { f:'Timesheet Data',                from:'Simpro', to:'EH Payroll', dir:'to-eh',  s:'custom' },
        { f:'Job Codes & Cost Centres',      from:'Simpro', to:'— Stays in Simpro', dir:'boundary', s:'boundary' },
      ],
      notes:[
        { icon:'🔧', title:'Single Partner — Aloka', body:'All three integrations are custom-built and managed by Aloka. Aloka can map any desired field from Employment Hero HR or EH Payroll into Simpro — one partner, one scope of work, tailored field mapping across all three platforms.' },
        { icon:'🔄', title:'EH HR ↔ EH Payroll (Bidirectional)', body:'Employee profiles, leave balances and payslips sync bidirectionally between EH HR and EH Payroll, keeping both platforms aligned without manual re-entry.' },
        { icon:'🔐', title:'Certification-Gated Dispatch', body:'Aloka can configure Simpro to check certification currency from EH HR before dispatching a technician — a powerful compliance safeguard for field teams.' },
        { icon:'🤝', title:'Engage Aloka During the Sale', body:'Aloka should be brought into the sales process early to scope all three connection points and confirm feasibility.' },
      ]
    }
  };

  // ── RENDER ────────────────────────────────────────────────────────────────
  function renderResult() {
    const cfg = (state.hr && state.payroll) ? INT.both : state.hr ? INT.hr : INT.payroll;
    document.getElementById('result-inner').innerHTML = buildResult(cfg);
    document.getElementById('result-panel').classList.add('visible');
    document.getElementById('show-btn-row').style.display = 'none';
    setTimeout(() => document.getElementById('result-panel').scrollIntoView({ behavior:'smooth', block:'start' }), 50);
  }

  function arrowHTML(dir) {
    const right = dir === 'r';
    return `<div class="arrow-track">
      <div class="arrow-line ${right?'to-right':'to-left'}"></div>
      ${right?'<div class="arrowhead-r"></div>':'<div class="arrowhead-l"></div>'}
    </div>`;
  }

  function renderConnector(arrows, vCls, vLbl, aboveCount) {
    const mid = (aboveCount !== undefined) ? aboveCount : Math.ceil(arrows.length / 2);
    return `<div class="flow-connector">
      ${arrows.slice(0,mid).map((a,i)=>`<div class="arrow-row"${i===0?' style="border-top:none"':''}><div class="arrow-lbl">${a.lbl}</div>${arrowHTML(a.dir)}</div>`).join('')}
      <div class="flow-via ${vCls}">${vLbl}</div>
      ${arrows.slice(mid).map(a=>`<div class="arrow-row"><div class="arrow-lbl">${a.lbl}</div>${arrowHTML(a.dir)}</div>`).join('')}
    </div>`;
  }

  function renderSecs(secs) {
    return secs.map(s=>`
      <div>
        <span class="flow-sec-label ${s.lCls}">${s.lbl}</span>
        <div class="flow-items">${s.items.map(i=>`<div class="flow-item">${i}</div>`).join('')}</div>
      </div>
      <div class="flow-divider"></div>
    `).join('');
  }
  function renderCallout(c) {
    return `<div class="flow-callout ${c.cls}"><span class="flow-callout-icon">${c.icon}</span>${c.txt}</div>`;
  }
  function dirBadge(d) {
    if (d==='to-sim')   return '<span class="dir-badge to-sim">→ Simpro</span>';
    if (d==='to-eh')    return '<span class="dir-badge to-eh">→ EH Payroll</span>';
    if (d==='bidir')    return '<span class="dir-badge bidir">↔ Bidirectional</span>';
    if (d==='boundary') return '<span class="dir-badge boundary">Stays in Simpro</span>';
    return '';
  }

  function buildResult(cfg) {
    let h = '';
    const isDark = currentTheme === 'dark';
    const arcColor = isDark ? '#bafc58' : '#7622d7';

    h += `
      <p class="section-hdr" style="margin-bottom:14px">Recommended Integration</p>
      <div class="partner-hero">
        <div class="partner-icon-wrap">${cfg.icon}</div>
        <div class="partner-info">
          <div class="partner-type">${cfg.partnerType}</div>
          <div class="partner-name">${cfg.name}</div>
          <div class="partner-tagline">${cfg.tagline}</div>
          <div class="partner-badge"><span class="dot"></span>${cfg.badge}</div>
        </div>
      </div>
      <div class="type-banner ${cfg.bannerCls}">
        <span class="type-banner-icon">${cfg.bannerIcon}</span>
        <div class="type-banner-text">
          <strong>${cfg.bannerTitle}</strong>
          <span>${cfg.bannerDesc}</span>
        </div>
      </div>
    `;

    h += `<div class="legend-bar">
      <span class="legend-lbl">Legend</span>
      <span class="legend-item"><span class="status-pill ootb">Out of the Box</span>&nbsp;Pre-built, no custom dev</span>
      <span class="legend-item"><span class="status-pill custom">Customisable</span>&nbsp;Tailored by partner</span>
    </div>`;

    h += `<p class="section-hdr" style="margin-bottom:14px">Data Flow Diagram</p>`;

    if (cfg.diagram === 'two') {
      h += `<div class="flow-diagram">
        <div class="flow-diagram-hdr">${cfg.c1.title} ↔ ${cfg.c2.title} · ${cfg.vLbl}</div>
        <div class="flow-body two-col">
          <div class="flow-col ${cfg.c1.cCls||''}">
            <div class="flow-col-head ${cfg.c1.hCls}"><div class="flow-col-head-title">${cfg.c1.title}</div><div class="flow-col-head-sub">${cfg.c1.sub}</div></div>
            <div class="flow-col-body">${renderSecs(cfg.c1.secs)}${renderCallout(cfg.c1.callout)}</div>
          </div>
          ${renderConnector(cfg.arrows, cfg.vCls, cfg.vLbl, cfg.aboveCount)}
          <div class="flow-col ${cfg.c2.cCls||''}">
            <div class="flow-col-head ${cfg.c2.hCls}"><div class="flow-col-head-title">${cfg.c2.title}</div><div class="flow-col-head-sub">${cfg.c2.sub}</div></div>
            <div class="flow-col-body">${renderSecs(cfg.c2.secs)}${renderCallout(cfg.c2.callout)}</div>
          </div>
        </div>
      </div>`;
    } else {
      h += `<div class="flow-diagram">
        <div class="flow-diagram-hdr">${cfg.cEH.title} × ${cfg.cSIM.title} × ${cfg.cPAY.title} · via Aloka</div>
        <div class="flow-body three-col">
          <div class="flow-col">
            <div class="flow-col-head ${cfg.cEH.hCls}"><div class="flow-col-head-title">${cfg.cEH.title}</div><div class="flow-col-head-sub">${cfg.cEH.sub}</div></div>
            <div class="flow-col-body">${renderSecs(cfg.cEH.secs)}${renderCallout(cfg.cEH.callout)}</div>
          </div>
          ${renderConnector(cfg.a1, cfg.v1Cls, cfg.v1Lbl)}
          <div class="flow-col sim-fcol">
            <div class="flow-col-head ${cfg.cSIM.hCls}"><div class="flow-col-head-title">${cfg.cSIM.title}</div><div class="flow-col-head-sub">${cfg.cSIM.sub}</div></div>
            <div class="flow-col-body">${renderSecs(cfg.cSIM.secs)}${renderCallout(cfg.cSIM.callout)}</div>
          </div>
          ${renderConnector(cfg.a2, cfg.v2Cls, cfg.v2Lbl)}
          <div class="flow-col">
            <div class="flow-col-head ${cfg.cPAY.hCls}"><div class="flow-col-head-title">${cfg.cPAY.title}</div><div class="flow-col-head-sub">${cfg.cPAY.sub}</div></div>
            <div class="flow-col-body">${renderSecs(cfg.cPAY.secs)}${renderCallout(cfg.cPAY.callout)}</div>
          </div>
        </div>
        <div class="bidir-wrap">
          <div class="bidir-inner">
            <div class="bidir-label">↔ EH HR ↔ EH Payroll — bidirectional sync via Aloka</div>
            <svg viewBox="0 0 600 44" width="100%" style="max-width:540px;display:block;margin:0 auto" fill="none">
              <defs>
                <marker id="aR" markerWidth="8" markerHeight="8" refX="7" refY="3.5" orient="auto"><path d="M0,0 L0,7 L8,3.5 z" fill="${arcColor}"/></marker>
                <marker id="aL" markerWidth="8" markerHeight="8" refX="1" refY="3.5" orient="auto-start-reverse"><path d="M0,0 L0,7 L8,3.5 z" fill="${arcColor}"/></marker>
                <linearGradient id="arcG" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="${arcColor}" stop-opacity="0.8"/>
                  <stop offset="50%" stop-color="${arcColor}" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="${arcColor}" stop-opacity="0.8"/>
                </linearGradient>
              </defs>
              <path d="M 55,8 C 190,44 410,44 545,8" fill="none" stroke="url(#arcG)" stroke-width="2" marker-start="url(#aL)" marker-end="url(#aR)"/>
            </svg>
            <div class="bidir-pills">${cfg.bidirFields.map(f=>`<span class="bidir-pill">${f}</span>`).join('')}</div>
          </div>
        </div>
      </div>`;
    }

    const tableHdr = cfg.name === 'Syncezy' ? 'Synced Fields &amp; Integration Type' : 'Example Synced Fields &amp; Integration Type';
    h += `<p class="section-hdr" style="margin-bottom:14px">Data Points at a Glance</p>
    <div class="data-table">
      <div class="data-table-hdr">${tableHdr}</div>
      <table>
        <thead><tr><th>Data Field</th><th>From</th><th>To</th><th>Direction</th><th>Integration Type</th></tr></thead>
        <tbody>${cfg.dp.map(dp=>`<tr>
          <td>${dp.f}</td><td>${dp.from}</td><td>${dp.to}</td>
          <td>${dirBadge(dp.dir)}</td>
          <td>${dp.s==='boundary'
            ? `<span style="font-size:11px;color:var(--boundary-color);font-style:italic">Intentional boundary</span>`
            : `<span class="status-pill ${dp.s}">${dp.s==='ootb'?'Out of the Box':'Customisable'}</span>`
          }</td>
        </tr>`).join('')}</tbody>
      </table>
    </div>`;

    h += `<p class="section-hdr" style="margin-bottom:14px">Key Considerations for Sales</p>
    <div class="notes-grid">${cfg.notes.map(n=>`
      <div class="note-card">
        <span class="note-card-icon">${n.icon}</span>
        <div class="note-card-title">${n.title}</div>
        <div class="note-card-body">${n.body}</div>
      </div>`).join('')}
    </div>`;

    return h;
  }
</script>
</body>
</html>
