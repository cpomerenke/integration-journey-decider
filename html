    updateShowBtn();
  }
  function updateShowBtn() {
    document.getElementById('show-btn-row').style.display = (state.hr || state.payroll) ? 'block' : 'none';
  }
  function showIntegrationOptions() {
    ['hr','payroll'].forEach(id => document.getElementById('card-' + id).classList.add('locked'));
    renderResult();
